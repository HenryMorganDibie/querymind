# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

# ── Pro tier — QueryMind's own LLM key ────────────────────────────────────────
# Pro users don't need their own key — QueryMind uses this
QM_PROVIDER=groq
QM_API_KEY=gsk_your_groq_key_here
QM_MODEL=llama-3.3-70b-versatile

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...   # your $19/mo recurring price ID

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Database path (Render persistent disk or /tmp for testing) ────────────────
DB_PATH=/data/querymind.db
